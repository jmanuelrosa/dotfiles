{
  "sandbox": {
    "enabled": true,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "allowRead": [".", ".env.*.example"],
      "allowWrite": ["."],
      "denyRead": ["~/", ".env", ".env.*"],
      "denyWrite": ["/"]
    }
  },
  "permissions": {
    "deny": ["Edit(.env*)", "Bash(*\\.env*)"]
  }
}
