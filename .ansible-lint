skip_list:
  - yaml[truthy]
  - var-naming

warn_list:
  - internal-error  # syntax-check fails without real vault password

exclude_paths:
  - inventory.yml  # INI format, not YAML — linter misdetects it
  - vars/secrets.yml
  - vars/work.yml
  - roles/work/files/  # static config files, not Ansible YAML
  - roles/ai/files/  # vendored skills/agents and Claude config, not Ansible YAML
