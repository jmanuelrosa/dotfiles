{
  // Startup edit
  "workbench.startupEditor": "none",
  // Force open files in new tabs
  "workbench.editor.enablePreview": false,

  // Breadcrumbs
  "breadcrumbs.enabled": true,

  // Style
  "workbench.colorTheme": "GitHub Dark Dimmed",

  "editor.fontFamily": "FiraCode Nerd Font",
  "editor.fontLigatures": true,
  "editor.fontSize": 12,

  "editor.rulers": [80],
  "editor.stickyScroll.enabled": true,
  "editor.tabSize": 2,
  "editor.autoIndent": "keep",

  // Hide minimap
  "editor.minimap.enabled": false,

  // Bracket colors
  "editor.bracketPairColorization.enabled": true,
  "editor.bracketPairColorization.independentColorPoolPerBracketType": true,

  // Security
  "security.workspace.trust.untrustedFiles": "open",

  // Search
  "search.exclude": {
    "**/.git": true,
    "**/.astro": true
  },
  "search.sortOrder": "modified",

  // Suggestions
  "editor.quickSuggestions": {
    "strings": "on"
  },

  // File associations
  "files.associations": {
    "*.css": "tailwindcss"
  },

  // -------------------------------- Extensions
  "extensions.allowed": {
    "eamodio.gitlens": true,
    "biomejs.biome": true,
    "EditorConfig.EditorConfig": true,
    "usernamehw.errorlens": false,
    "GitHub.github-vscode-theme": true,
    "YoavBls.pretty-ts-errors": false,
    "astro-build.astro-vscode": true,
    "Anthropic.claude-code": true,
    "Prisma.prisma": false,
    "bradlc.vscode-tailwindcss": true
  },

  "biome.enabled": true,

  // Prisma
  "prisma.fileWatcher": false,
  "prisma.enableDiagnostics": false,
  "prisma.enableCodeLens": false,

  // Tailwinds
  "tailwindcss-intellisense.trace.server": "messages",
  "tailwindCSS.classAttributes": [
    "class",
    "className",
    "class:list"
  ],
  "tailwindCSS.includeLanguages": {
    "astro": "html",
    "html": "html",
    "javascript": "javascript",
    "javascriptreact": "javascript",
    "typescript": "typescript",
    "typescriptreact": "typescript",
    "css": "css"
  },
  "tailwindCSS.codeActions": false,
  "tailwindCSS.codeLens": false,
  "tailwindCSS.emmetCompletions": false,
  "tailwindCSS.suggestions": false,
  "tailwindCSS.validate": false,

  // Claude
  "claudeCode.preferredLocation": "sidebar",
  "chat.hookFilesLocations": {
    "~/.copilot/hooks": false
  },
  "git.detectWorktrees": true,
  "git.detectWorktreesLimit": 10,
}
