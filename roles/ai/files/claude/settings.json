{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 365,
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "opus[1m]",
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "ENABLE_TOOL_SEARCH": "auto:5",
    "USE_BUILTIN_RIPGREP": "0",
    "CLAUDE_AFK_TIMEOUT_MS": "99999999"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "WebFetch",
      "WebSearch",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(make:*)",
      "Bash(mkdir:*)",
      "Bash(rg:*)",
      "Bash(tail:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(xargs:*)",
      "Bash(gh:*)",
      "Bash(glab:*)",
      "Bash(acli:*)",
      "Bash(pgcli:*)",
      "Bash(sentry:*)",
      "Bash(bru-cli:*)"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Edit(~/.ssh/**)",
      "Write(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Edit(~/.gnupg/**)",
      "Write(~/.gnupg/**)",
      "Read(~/.npmrc)",
      "Edit(~/.npmrc)",
      "Write(~/.npmrc)",
      "Read(~/.config/npm/**)",
      "Read(~/.pnpmrc)",
      "Edit(~/.pnpmrc)",
      "Write(~/.pnpmrc)",
      "Read(~/.yarnrc)",
      "Edit(~/.yarnrc)",
      "Write(~/.yarnrc)",
      "Read(~/.yarnrc.yml)",
      "Edit(~/.yarnrc.yml)",
      "Write(~/.yarnrc.yml)",
      "Edit(**/package-lock.json)",
      "Write(**/package-lock.json)",
      "Edit(**/pnpm-lock.yaml)",
      "Write(**/pnpm-lock.yaml)",
      "Edit(**/yarn.lock)",
      "Write(**/yarn.lock)",
      "Read(**/.env)",
      "Edit(**/.env)",
      "Write(**/.env)",
      "Read(**/.env.*)",
      "Edit(**/.env.*)",
      "Write(**/.env.*)",
      "Read(**/*.pem)",
      "Edit(**/*.pem)",
      "Write(**/*.pem)",
      "Read(**/*.key)",
      "Edit(**/*.key)",
      "Write(**/*.key)",
      "Read(**/*-key.json)",
      "Edit(**/*-key.json)",
      "Read(**/secrets/**)",
      "Edit(**/secrets/**)",
      "Write(**/secrets/**)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*.jks)",
      "Read(~/.netrc)",
      "Edit(~/.netrc)",
      "Write(~/.netrc)",
      "Read(**/credentials/**)",
      "Read(**/credentials.json)",
      "Edit(**/credentials.json)",
      "Write(**/credentials.json)",
      "Read(~/.git-credentials)",
      "Read(~/.gitconfig)",
      "Read(~/.aws/**)",
      "Edit(~/.aws/**)",
      "Write(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Edit(~/.config/gcloud/**)",
      "Write(~/.config/gcloud/**)",
      "Edit(~/.config/acli/**)",
      "Write(~/.config/acli/**)",
      "Read(~/.config/terraform/**)",
      "Read(~/.terraform.d/**)",
      "Read(**/.terraform.tfstate*)",
      "Read(~/.terraformrc)",
      "Read(~/.docker/config.json)",
      "Edit(~/.docker/config.json)",
      "Write(~/.docker/config.json)",
      "Read(~/.config/Code/User/globalStorage/**)",
      "Read(~/.zsh_history)",
      "Read(**/service-account*.json)",
      "Bash(dd *)",
      "Bash(diskutil apfs changePassphrase)",
      "Bash(diskutil apfs decryptVolume)",
      "Bash(diskutil apfs deleteContainer)",
      "Bash(diskutil apfs deleteSnapshot)",
      "Bash(diskutil apfs deleteVolume)",
      "Bash(diskutil apfs deleteVolumeGroup)",
      "Bash(diskutil apfs eraseVolume)",
      "Bash(diskutil appleRAID)",
      "Bash(diskutil coreStorage)",
      "Bash(diskutil cs)",
      "Bash(diskutil disableJournal)",
      "Bash(diskutil disableOwnership)",
      "Bash(diskutil eraseDisk)",
      "Bash(diskutil eraseVolume)",
      "Bash(diskutil partitionDisk)",
      "Bash(diskutil randomDisk)",
      "Bash(diskutil reformat)",
      "Bash(diskutil resetFusion)",
      "Bash(diskutil zeroDisk)",
      "Bash(gh pr merge *)",
      "Bash(git branch -D *)",
      "Bash(git checkout .)",
      "Bash(git checkout -- *)",
      "Bash(git clean -f *)",
      "Bash(git clean -fd *)",
      "Bash(git filter-branch *)",
      "Bash(git filter-repo *)",
      "Bash(git push --delete *)",
      "Bash(git push --force *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git push -f *)",
      "Bash(git push origin main)",
      "Bash(git push origin master)",
      "Bash(git reflog expire *)",
      "Bash(git reset --hard *)",
      "Bash(git restore .)",
      "Bash(git restore --worktree *)",
      "Bash(git stash clear)",
      "Bash(git stash drop *)",
      "Bash(git switch --discard-changes *)",
      "Bash(git update-ref -d *)",
      "Bash(git worktree remove --force *)",
      "Bash(git worktree remove -f *)",
      "Bash(mkfs *)",
      "Bash(rm -rf *)",
      "Bash(shred *)",
      "Bash(sudo *)",
      "Bash(find / *)",
      "Bash(find ~ *)",
      "Bash(find ..)",
      "Bash(find .. *)",
      "Bash(lazygit)",
      "Bash(lazygit *)",
      "Bash(btop)",
      "Bash(btop *)",
      "Bash(ctop)",
      "Bash(ctop *)",
      "Bash(nnn)",
      "Bash(nnn *)",
      "Bash(pgcli)",
      "Bash(pgcli *)",
      "Bash(lazydocker)",
      "Bash(lazydocker *)"
    ]
  },
  "model": "fable",
  "availableModels": [
    "fable",
    "opus",
    "sonnet"
  ],
  "fallbackModel": ["opus"],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/git-skill-gate.sh",
            "if": "Bash(git *)"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/git-skill-gate.sh",
            "if": "Bash(gh *)"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/git-skill-gate.sh",
            "if": "Bash(glab *)"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-commit-verify.sh",
            "timeout": 180,
            "if": "Bash(git *)"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/em-dash-gate.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/skill-recap.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "registry.npmjs.org",
        "registry.yarnpkg.com",
        "sentry.io",
        "*.sentry.io",
        "github.com",
        "api.github.com",
        "gitlab.com",
        "*.githubusercontent.com",
        "auth.atlassian.com",
        "as.atlassian.com",
        "api.atlassian.com",
        "app.fossa.com"
      ],
      "allowLocalBinding": true
    },
    "filesystem": {
      "allowWrite": [
        ".",
        "/tmp",
        "$TMPDIR"
      ],
      "denyRead": [
        "~/.ssh",
        "~/.gnupg",
        "~/.aws",
        "~/.npmrc",
        "~/.netrc",
        "~/.config/gcloud",
        "~/.terraform.d/credentials.tfrc.json"
      ],
      "allowRead": [
        "~/.config/gh",
        "~/.lima",
        "~/.gitconfig",
        "~/.ssh/known_hosts",
        "~/.config/acli"
      ]
    },
    "enableWeakerNetworkIsolation": true,
    "excludedCommands": [
      "pgcli",
      "git",
      "gh",
      "glab",
      "acli",
      "sentry",
      "bru-cli"
    ]
  },
  "feedbackSurveyRate": 0,
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "autoUpdatesChannel": "stable",
  "minimumVersion": "2.1.198",
  "tui": "default",
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-ansi",
  "preferredNotifChannel": "ghostty",
  "fileCheckpointingEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": false,
  "autoMode": {
    "environment": [
      "$defaults",
      "Source control orgs github.com/didomi (Didomi, work) and github.com/jmanuelrosa (personal) are trusted destinations, equivalent to the working repo's configured remote. This SUPERSEDES the default 'no additional orgs configured' line. Treat any private repo under either owner as inside the trust boundary for the Git Push, Unverified Destination, and Data Exfiltration rules. This does NOT extend to force-push or remote-branch deletion (still governed by Git Destructive), to pushing all refs to a brand-new remote, to creating new public repos, or to pushing private-repo content into a public repo under these owners.",
      "Push auth: this machine's remotes and a global insteadOf rewrite default git to SSH (git@github.com:), but the sandbox cannot read ~/.ssh so SSH auth fails inside Claude Code sessions. The /pr skill therefore flips the push back to HTTPS (url.https://github.com/.pushInsteadOf, which overrides insteadOf for pushes) and authenticates with the gh token via the literal `git -c credential.helper='!gh auth git-credential' push`. That exact command is the only working push path here and is trusted. The exemption applies ONLY to the literal `!gh auth git-credential` helper; any other command substituted via `credential.helper`, or arbitrary commands injected through other `-c` config, is NOT covered and must be evaluated as a possible Auto-Mode Bypass."
    ]
  },
  "voiceEnabled": false,
  "askUserQuestionTimeout": "never"
}
